; APP ENV 
; CRITICAL: Must be 'production' for production deployments to prevent WebSocket errors
NODE_ENV=production
AUTH_TRUST_HOST=true

; NEXTAUTH_URL: Must match your actual domain in production
; Examples:
; - Development: http://localhost:3000
; - Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000  
NEXTAUTH_SECRET="your-default-secret-key"   

; POSTGRES (Default DB Provider - Priority 1)
; Supports standard PostgreSQL connection strings including Docker deployments
; Examples:
; - Local/Docker: postgresql://myuser:strongpassword@localhost:5432/myappdb
; - Cloud: postgresql://user:pass@your-postgres-server?sslmode=require
POSTGRES_URL=postgresql://myuser:strongpassword@db:5432/myappdb
; Set to TRUE to allow insecure connections (e.g. self-signed certs) - Not recommended for production
POSTGRES_ALLOW_INSECURE=false
 
; FIREBASE (Alternative DB Provider - Priority 2)
; Hosting & Real-time Database configuration for Firebase - Only used if POSTGRES_URL is not set
; Requires FIREBASE_DATABASE_URL to be set for Firebase to be used as database provider
; FIREBASE_API_KEY=XXXXXXXXXXX
; FIREBASE_AUTH_DOMAIN=xxxxx.firebaseapp.com
; FIREBASE_PROJECT_ID=xxxxx
; FIREBASE_STORAGE_BUCKET=xxxxx.firebasestorage.app
; FIREBASE_MESSAGING_SENDER_ID=0000000000000
; FIREBASE_APP_ID=1:0000000000000:web:XX000000
; FIREBASE_DATABASE_URL=https://xxxxx-default-rtdb.europe.firebasedatabase.app
